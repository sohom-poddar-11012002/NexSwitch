# Copy this to .env and fill in values. NEVER commit .env
# Local dev defaults are safe to use as-is

# Database
DB_URL=jdbc:postgresql://localhost:5432/payments
DB_USERNAME=payments_app
DB_PASSWORD=local_dev_password

# Redis
REDIS_HOST=localhost
REDIS_PASSWORD=local_dev_password

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# Adapters (swap for staging/prod)
UPSTREAM_PROVIDER=wiremock       # wiremock | razorpay | npci
HSM_PROVIDER=mock                # mock | softhsm
STORAGE_PROVIDER=local           # local | s3

# AWS (only needed when STORAGE_PROVIDER=s3)
AWS_REGION=ap-south-1
S3_BUCKET=payments-platform-local

# HSM (only needed when HSM_PROVIDER=softhsm)
HSM_PKCS11_LIB=/usr/lib/softhsm/libsofthsm2.so
HSM_TOKEN_PIN=1234
HSM_SO_PIN=5678

# Email
SPRING_MAIL_HOST=localhost
SPRING_MAIL_PORT=1025

# Razorpay (only needed when UPSTREAM_PROVIDER=razorpay — post-June)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Operations
OPS_EMAIL=ops@payments-platform.local
