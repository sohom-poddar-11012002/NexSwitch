# Secrets — NEVER commit
.env
*.key
*.pem
*.p12
*.jks

# Maven
target/
.mvn/wrapper/maven-wrapper.jar
!**/src/main/**/target/
!**/src/test/**/target/

# IDE
.idea/
.vscode/
*.iml
.classpath
.project
.settings/
*.class
postman/
.postman/

# Logs
*.log
logs/

# macOS
.DS_Store

# Docker volumes (generated)
pgdata/

# Frontend build artifacts
frontend/*/node_modules/
frontend/*/dist/
frontend/*/.vite/
frontend/*/*.tsbuildinfo

# LocalStack data
.localstack/

# SoftHSM2 tokens (never commit HSM state)
softhsm2-tokens/
softhsm2.conf

# Claude Code — local tooling state, not project source
.claude/
.dual-graph/

# Project requirements doc — contains personal/career info, kept local only
CLAUDE.md

# Sprint context — Claude reads this locally; never committed
CONTEXT.md

# Spec files — extracted from CLAUDE.md, local only, dual-graph indexed
docs/specs/